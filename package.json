{
  "name": "photobooth-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"js/**/*.ts\" \"__tests__/**/*.js\" \"docs/**/*.md\" \"index.html\"",
    "format:check": "prettier --check \"js/**/*.ts\" \"__tests__/**/*.js\" \"docs/**/*.md\" \"index.html\"",
    "ci": "npm run lint && npm run typecheck && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "eslint": "8.57.1",
    "fast-check": "3.22.0",
    "jsdom": "25.0.1",
    "prettier": "3.3.3",
    "typescript": "5.8.3",
    "vite": "5.4.19",
    "vitest": "2.1.8"
  }
}
